{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"],
      "@task-view/ui/*": ["../../packages/ui/*"],
      "@task-view/server/*": ["../../packages/server/*"],
      "@task-view/shared/*": ["../../packages/shared/*"],
      "@task-view/schemas/*": ["../../packages/schemas/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}